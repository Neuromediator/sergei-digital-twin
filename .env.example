# --- Required: Anthropic (default provider, Claude Haiku 4.5) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Optional: swap the inference provider for raw speed ---
# Leave unset (or "anthropic") to use Claude Haiku 4.5.
# Set to "groq" or "cerebras" to stream from an OpenAI-compatible open-model
# endpoint instead (faster tokens/sec, cheaper, open-model quality tradeoff).
# LLM_PROVIDER=groq

# Groq (https://console.groq.com) — needed only if LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# Cerebras (https://cloud.cerebras.ai) — needed only if LLM_PROVIDER=cerebras
# CEREBRAS_API_KEY=csk-...
# CEREBRAS_MODEL=llama-3.3-70b
